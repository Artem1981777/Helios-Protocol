# Copy this file to `casper-test.env` and fill in your values.
# Run the deploy with:
#   ODRA_CASPER_LIVENET_ENV=casper-test cargo run --bin helios_vault_on_livenet --features livenet

# Path to the secret key (PEM) of the funded account that pays for the deploy.
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=./keys/secret_key.pem

# Testnet RPC node. CSPR.cloud is part of the Casper AI Toolkit (free token at
# https://console.cspr.cloud). You can also point this at any public Testnet node RPC.
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.cspr.cloud
ODRA_CASPER_LIVENET_EVENTS_URL=https://node.testnet.cspr.cloud/events

# Testnet chain name (mainnet would be "casper").
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test

# Required if you use a CSPR.cloud node address. Leave empty for a raw public node.
CSPR_CLOUD_AUTH_TOKEN=

# Optional: deploy time-to-live (default 5 minutes).
# ODRA_CASPER_LIVENET_TTL=
